# ─────────────────────────────────────────────────────────────
# .env.example — Copy to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────

# ── LiveKit Cloud ─────────────────────────────────────────────
# Get these from https://cloud.livekit.io → your project
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Session secret ───────────────────────────────────────────
# Must be 32+ random characters. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# ── Host credentials ─────────────────────────────────────────
# The host account is defined here, not in the database.
HOST_USER_ID=
HOST_PASSWORD=
HOST_GENDER=MALE
HOST_LANGUAGE=EN

# ── Upstash Redis ─────────────────────────────────────────────
# Get from https://console.upstash.com or Vercel Marketplace
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
